{
  "name": "pretext-react-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @santjc/playground",
    "build": "npm run build -w @santjc/react-pretext && npm run build -w @santjc/playground",
    "lint": "npm run lint -w @santjc/react-pretext && npm run lint -w @santjc/playground",
    "test": "npm run test -w @santjc/react-pretext && npm run test -w @santjc/playground",
    "version:react-pretext:patch": "npm version patch --no-git-tag-version -w @santjc/react-pretext",
    "version:react-pretext:minor": "npm version minor --no-git-tag-version -w @santjc/react-pretext",
    "version:react-pretext:prerelease": "npm version prerelease --preid beta --no-git-tag-version -w @santjc/react-pretext"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^27.0.1",
    "react-router-dom": "^7.9.3",
    "tsup": "^8.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.0.8"
  }
}
