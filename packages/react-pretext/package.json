{
  "name": "@santjc/react-pretext",
  "version": "1.0.0",
  "description": "Thin React primitives over @chenglou/pretext with an advanced editorial subpath.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pretext": {
      "types": "./dist/pretext.d.ts",
      "import": "./dist/pretext.js"
    },
    "./editorial": {
      "types": "./dist/editorial.d.ts",
      "import": "./dist/editorial.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "pretext",
    "text-measurement",
    "typography",
    "layout",
    "editorial-layout",
    "newspaper-layout",
    "text-flow"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/pretext.ts src/editorial.ts --format esm --dts",
    "lint": "eslint src",
    "test": "vitest run --config vitest.config.ts"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3"
  }
}
